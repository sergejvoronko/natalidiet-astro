{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "image": {
      "type": "string"
    },
    "course": {
      "type": "string",
      "enum": [
        "breakfast",
        "lunch",
        "dinner",
        "snack"
      ]
    },
    "cuisine": {
      "default": "Eastern European",
      "type": "string"
    },
    "prepTime": {
      "type": "number"
    },
    "cookTime": {
      "type": "number"
    },
    "totalTime": {
      "type": "number"
    },
    "servings": {
      "default": 1,
      "type": "number"
    },
    "calories": {
      "type": "number"
    },
    "protein": {
      "type": "number"
    },
    "carbs": {
      "type": "number"
    },
    "fat": {
      "type": "number"
    },
    "fibre": {
      "type": "number"
    },
    "tags": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "category": {
      "type": "string"
    },
    "tip": {
      "type": "string"
    },
    "publishDate": {
      "type": "string",
      "format": "date-time"
    },
    "ingredients": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        },
        "required": [
          "amount",
          "name"
        ]
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "featured": {
      "default": false,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "course",
    "prepTime",
    "cookTime",
    "totalTime",
    "calories",
    "protein",
    "carbs",
    "fat",
    "category",
    "publishDate",
    "ingredients",
    "steps"
  ]
}