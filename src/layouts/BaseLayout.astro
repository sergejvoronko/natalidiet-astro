---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEOHead from '../components/SEOHead.astro';
import CookieConsent from '../components/CookieConsent.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  noIndex?: boolean;
  type?: 'website' | 'article';
  fullWidth?: boolean;
}

const { title, description, canonical, image, noIndex = false, type = 'website', fullWidth = false } = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="apple-touch-icon" href="/favicon.png" />
  <link rel="preload" href="/fonts/PlayfairDisplay-Variable.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/DMSans-Variable.woff2" as="font" type="font/woff2" crossorigin />
  <SEOHead
    title={title}
    description={description}
    canonical={canonical}
    image={image}
    noIndex={noIndex}
    type={type}
  />
</head>
<body>
  <Header />
  <main class:list={['nd-main', { 'full-width': fullWidth }]}>
    <slot />
  </main>
  <Footer />
  <CookieConsent />
  <script is:inline>
    (function(w,d,e,u,f,l,n){w[f]=w[f]||function(){(w[f].q=w[f].q||[]).push(arguments);},
    l=d.createElement(e),l.async=1,l.src=u,n=d.getElementsByTagName(e)[0],n.parentNode.insertBefore(l,n);})
    (window,document,'script','https://assets.mailerlite.com/js/universal.js','ml');
    ml('account', '2334622');
  </script>
</body>
</html>

<style is:global>
  .nd-main {
    padding-top: var(--nav-height);
    min-height: 80vh;
  }
  .nd-main.full-width {
    padding-top: 0;
  }
</style>
