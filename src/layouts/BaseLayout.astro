---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEOHead from '../components/SEOHead.astro';
import CookieConsent from '../components/CookieConsent.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  noIndex?: boolean;
  type?: 'website' | 'article';
  fullWidth?: boolean;
}

const { title, description, canonical, image, noIndex = false, type = 'website', fullWidth = false } = Astro.props;

const siteUrl = 'https://natalidiet.eu';
const siteSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': siteUrl + '/#website',
      name: 'Natali Diet',
      url: siteUrl + '/',
      description: 'Eastern and Central European recipes adapted for healthy eating and weight loss.',
      publisher: { '@id': siteUrl + '/#organization' },
      inLanguage: 'en',
    },
    {
      '@type': 'Organization',
      '@id': siteUrl + '/#organization',
      name: 'Natali Diet',
      url: siteUrl + '/',
      logo: { '@type': 'ImageObject', url: siteUrl + '/images/logo.png' },
      founder: { '@id': siteUrl + '/about/#natali' },
    },
    {
      '@type': 'Person',
      '@id': siteUrl + '/about/#natali',
      name: 'Natali',
      url: siteUrl + '/about/',
      image: siteUrl + '/images/natali-profile.webp',
      jobTitle: 'Recipe Developer & Healthy Eating Author',
      knowsAbout: ['Eastern European cuisine', 'healthy cooking', 'weight loss nutrition'],
      worksFor: { '@id': siteUrl + '/#organization' },
    },
  ],
};
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="apple-touch-icon" href="/favicon.png" />
  <link rel="preload" href="/fonts/PlayfairDisplay-Variable.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/DMSans-Variable.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preconnect" href="https://assets.mailerlite.com" />
  <link rel="preconnect" href="https://static.mailerlite.com" />
  <link rel="preconnect" href="https://assets.mlcdn.com" />
  <link rel="preconnect" href="https://groot.mailerlite.com" />
  <SEOHead
    title={title}
    description={description}
    canonical={canonical}
    image={image}
    noIndex={noIndex}
    type={type}
  />
  <script type="application/ld+json" set:html={JSON.stringify(siteSchema)} />
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-08PEV2GJX1"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-08PEV2GJX1');
  </script>
</head>
<body>
  <Header />
  <main class:list={['nd-main', { 'full-width': fullWidth }]}>
    <slot />
  </main>
  <Footer />
  <CookieConsent />
  <script is:inline>
    (function(w,d,e,u,f,l,n){w[f]=w[f]||function(){(w[f].q=w[f].q||[]).push(arguments);},
    l=d.createElement(e),l.async=1,l.src=u,n=d.getElementsByTagName(e)[0],n.parentNode.insertBefore(l,n);})
    (window,document,'script','https://assets.mailerlite.com/js/universal.js','ml');
    ml('account', '2334622');
  </script>
</body>
</html>

<style is:global>
  .nd-main {
    padding-top: var(--nav-height);
    min-height: 80vh;
  }
  .nd-main.full-width {
    padding-top: 0;
  }
</style>
