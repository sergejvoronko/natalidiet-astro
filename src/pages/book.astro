---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQBlock from '../components/FAQBlock.astro';

const bookFaqs = [
  { q: 'Is this a one-time purchase or a subscription?', a: 'One-time payment of €19.99. No subscription, no recurring charges — you pay once and the book is yours to keep.' },
  { q: 'What format is the book and what devices does it work on?', a: 'A downloadable PDF. It opens on any phone, tablet, laptop, or e-reader, and you can print it if you prefer cooking from paper.' },
  { q: 'How quickly do I get it after buying?', a: 'Instantly. The download link is delivered the moment your payment goes through — no waiting for shipping.' },
  { q: 'Do I need special ingredients or equipment?', a: 'No. Every recipe uses ordinary supermarket ingredients and standard kitchen equipment. The 32 recipes are built around real Eastern European staples like kefir, buckwheat, cottage cheese, and seasonal vegetables.' },
  { q: 'What if it is not for me?', a: '30-day money-back guarantee, no questions asked. If the book is not a fit, email contact@natalidiet.eu within 30 days for a full refund.' },
];
---

<BaseLayout
  title="Get the Recipe Book — €19.99"
  description="32 calorie-counted Eastern European recipes in an 8-day meal plan. Nutritionist-crafted, macro-balanced, with a complete shopping list. PDF download."
>
  <div class="book-page">
    <!-- Hero -->
    <section class="book-hero">
      <div class="book-hero-inner">
        <div class="book-hero-left">
          <span class="section-label" style="color: var(--nd-terra-light);">The Recipe Book</span>
          <h1 class="book-title">32 healthy recipes.<br><em>One beautiful plan.</em></h1>
          <p class="book-desc">
            Eastern European cuisine adapted for healthy eating — 8 days, 4 meals a day.
            Every recipe is calorie-counted, macro-balanced, and designed to actually taste good.
          </p>
          <div class="book-includes">
            <div class="include-item"><span aria-hidden="true">✓</span> 32 recipes across an 8-day plan</div>
            <div class="include-item"><span aria-hidden="true">✓</span> Breakfast, lunch, snack &amp; dinner every day</div>
            <div class="include-item"><span aria-hidden="true">✓</span> Full nutrition info — protein, carbs, fat, fibre</div>
            <div class="include-item"><span aria-hidden="true">✓</span> Complete shopping list included</div>
            <div class="include-item"><span aria-hidden="true">✓</span> Instant PDF download</div>
          </div>
          <div class="book-cta-row">
            <div class="book-price">
              <span class="price-amount">€19.99</span>
              <span class="price-sub">One-time · Instant download</span>
            </div>
            <a href="#buy" class="btn-primary btn-large">Get the Book →</a>
          </div>
          <p class="book-guarantee">30-day money-back guarantee. No questions asked.</p>
        </div>
        <div class="book-hero-right" aria-hidden="true">
          <div class="book-visual">
            <div class="book-cover-wrap">
              <img src="/images/book-cover.webp" alt="Natali Diet Recipe Book" class="book-cover-photo" width="280" height="373" loading="eager" />
            </div>
            <div class="book-shadow"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- What's inside -->
    <section class="inside-section">
      <div class="inside-inner">
        <div class="inside-header">
          <span class="section-label">What's inside</span>
          <h2 class="section-title">Everything you need to<br>transform how you <em>eat</em></h2>
        </div>
        <div class="inside-grid">
          {[
            { icon: '🥣', title: 'Soups & Light Lunches', desc: 'Cold okroshka, sauerkraut broth, mushroom barley — all under 300 kcal and ready in under 30 minutes.' },
            { icon: '🍳', title: 'Breakfasts & Snacks',   desc: 'Syrniki, kefir porridge, rye crispbreads — proper Eastern European starts that keep you full until lunch.' },
            { icon: '📅', title: '8-Day Meal Plan',        desc: 'Every day has breakfast, lunch, snack, and dinner — all planned, all calorie-counted, ready to follow.' },
            { icon: '🥟', title: 'Traditional Classics',   desc: 'Varenyky, kotlety, vinegret, stuffed peppers — reimagined lighter without losing the soul.' },
            { icon: '📊', title: 'Full Nutrition Data',    desc: 'Every recipe shows calories, protein, carbs, fat, and fibre per serving. No guesswork.' },
            { icon: '🛒', title: 'Complete Shopping List', desc: 'One master list covering all 32 recipes — organised by category so you can shop in one go.' },
          ].map(item => (
            <div class="inside-card">
              <div class="inside-icon" aria-hidden="true">{item.icon}</div>
              <h3 class="inside-title">{item.title}</h3>
              <p class="inside-desc">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Testimonials -->
    <section class="book-testi">
      <div class="book-testi-inner">
        <h2 class="section-title" style="text-align: center; margin-bottom: 48px;">What readers say</h2>
        <div class="testi-row">
          {[
            { text: "I lost 12kg in 4 months and genuinely love cooking now. This is not a diet book — it's a lifestyle.", name: 'Olena M.', loc: 'Kyiv, Ukraine' },
            { text: "The only cookbook I've cooked from more than twice. Fast, kid-friendly, and actually delicious.", name: 'Monika K.', loc: 'Bratislava' },
            { text: 'I had no idea buckwheat could taste this good. My gut health has improved dramatically.', name: 'James T.', loc: 'London, UK' },
          ].map(t => (
            <div class="mini-testi">
              <div class="mini-stars" aria-label="5 out of 5 stars">★★★★★</div>
              <p class="mini-text">"{t.text}"</p>
              <div class="mini-author">
                <span class="mini-avatar" aria-hidden="true">{t.name.charAt(0)}</span>
                <span>{t.name} · {t.loc}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="book-faq-section">
      <div class="book-faq-inner">
        <FAQBlock faqs={bookFaqs} />
      </div>
    </section>

    <!-- Buy section -->
    <section class="buy-section" id="buy">
      <div class="buy-inner">
        <span class="section-label">Get it now</span>
        <h2 class="section-title">Start your <em>journey</em> today</h2>
        <p class="section-body" style="margin-bottom: 36px; max-width: 400px;">
          Instant PDF download. Works on any device. 30-day money-back guarantee.
        </p>
        <div class="buy-price-box">
          <div class="buy-price">€19.99</div>
          <div class="buy-price-note">One-time payment · No subscription</div>
          <a href="/go/book" target="_blank" rel="noopener" class="btn-primary btn-large">
            Buy Now — €19.99 →
          </a>
          <p class="buy-guarantee">🛡️ 30-day money-back guarantee</p>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .book-hero { background: var(--nd-forest); padding: 80px 48px; }
  .book-hero-inner { max-width: var(--max-w); margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }
  .book-title { font-family: var(--font-serif); font-size: clamp(36px, 4.5vw, 58px); font-weight: 900; color: #fff; line-height: 1.08; letter-spacing: -0.03em; margin-bottom: 20px; }
  .book-title em { font-style: italic; color: var(--nd-terra-light); }
  .book-desc { font-size: 17px; font-weight: 300; color: rgba(255,255,255,0.6); line-height: 1.7; margin-bottom: 32px; max-width: 440px; }
  .book-includes { display: flex; flex-direction: column; gap: 10px; margin-bottom: 36px; }
  .include-item { display: flex; align-items: center; gap: 12px; font-size: 15px; color: rgba(255,255,255,0.8); font-weight: 400; }
  .include-item span { color: var(--nd-terra-light); font-weight: 700; }
  .book-cta-row { display: flex; align-items: center; gap: 28px; flex-wrap: wrap; margin-bottom: 16px; }
  .price-amount { font-family: var(--font-serif); font-size: 36px; font-weight: 900; color: #fff; display: block; }
  .price-sub { font-size: 12px; color: rgba(255,255,255,0.45); display: block; }
  .book-guarantee { font-size: 13px; color: rgba(255,255,255,0.4); }

  .book-visual { position: relative; }
  .book-cover-wrap {
    width: 280px;
    border-radius: 4px 16px 16px 4px;
    overflow: hidden;
    box-shadow: -8px 12px 40px rgba(0,0,0,0.5), 5px 0 0 rgba(255,255,255,0.04) inset;
    border-left: 6px solid rgba(255,255,255,0.06);
    position: relative; z-index: 1;
  }
  .book-cover-photo { width: 100%; height: auto; display: block; }
  .book-shadow { position: absolute; bottom: -20px; left: 20px; right: -20px; height: 40px; background: rgba(0,0,0,0.3); border-radius: 50%; filter: blur(16px); z-index: 0; }

  .inside-section { padding: 100px 48px; }
  .inside-inner { max-width: var(--max-w); margin: 0 auto; }
  .inside-header { text-align: center; margin-bottom: 60px; }
  .inside-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .inside-card { background: var(--nd-warm-white); border-radius: 20px; padding: 32px; box-shadow: var(--shadow-card); transition: transform 0.25s, box-shadow 0.25s; }
  .inside-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-hover); }
  .inside-icon { font-size: 40px; margin-bottom: 16px; }
  .inside-title { font-family: var(--font-serif); font-size: 19px; font-weight: 700; color: var(--nd-forest); margin-bottom: 10px; }
  .inside-desc { font-size: 14px; color: var(--nd-muted); line-height: 1.65; font-weight: 300; }

  .book-testi { background: #F2ECE3; padding: 80px 48px; }
  .book-testi-inner { max-width: var(--max-w); margin: 0 auto; }
  .testi-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .mini-testi { background: #fff; border-radius: 16px; padding: 28px; box-shadow: var(--shadow-card); transition: transform 0.25s, box-shadow 0.25s; }
  .mini-testi:hover { transform: translateY(-4px); box-shadow: var(--shadow-hover); }
  .mini-stars { color: var(--nd-gold); font-size: 15px; letter-spacing: 2px; margin-bottom: 14px; }
  .mini-text { font-size: 15px; font-style: italic; color: var(--nd-text); line-height: 1.7; font-weight: 300; margin-bottom: 18px; }
  .mini-author { display: flex; align-items: center; gap: 12px; font-size: 13px; font-weight: 600; color: var(--nd-muted); }
  .mini-avatar { display: inline-flex; align-items: center; justify-content: center; width: 34px; height: 34px; border-radius: 50%; background: var(--nd-forest); color: #fff; font-family: var(--font-serif); font-size: 15px; font-weight: 700; flex-shrink: 0; }

  .book-faq-section { padding: 90px 48px; background: var(--nd-warm-white); }
  .book-faq-inner { max-width: 760px; margin: 0 auto; }

  .buy-section { padding: 100px 48px; text-align: center; background: var(--nd-cream); }
  .buy-inner { max-width: 480px; margin: 0 auto; }
  .buy-price-box { background: var(--nd-warm-white); border: 2px solid var(--nd-border); border-radius: 24px; padding: 48px 36px; margin-top: 24px; }
  .buy-price { font-family: var(--font-serif); font-size: 56px; font-weight: 900; color: var(--nd-forest); letter-spacing: -0.03em; margin-bottom: 4px; }
  .buy-price-note { font-size: 14px; color: var(--nd-muted); margin-bottom: 32px; }
  .buy-guarantee { font-size: 14px; color: var(--nd-muted); margin-top: 20px; }

  @media (max-width: 900px) {
    .book-hero { padding: 48px 20px; }
    .book-hero-inner { grid-template-columns: 1fr; gap: 48px; }
    .book-hero-right { display: flex; justify-content: center; }
    .inside-section, .book-testi, .buy-section, .book-faq-section { padding: 72px 20px; }
    .inside-grid, .testi-row { grid-template-columns: 1fr; }
  }
</style>
