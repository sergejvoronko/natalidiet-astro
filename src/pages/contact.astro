---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact"
  description="Get in touch with questions about healthy recipes, consulting, partnerships, or just to say hello."
>
  <div class="contact-page">
    <div class="contact-inner">
      <div class="contact-info">
        <span class="section-label">Get in touch</span>
        <h1 class="contact-title">Let's talk<br><em>healthy food.</em></h1>
        <p class="contact-lead">
          Questions about a recipe, consulting, collaboration, or just want to share your results?
        </p>
        <div class="contact-cards">
          <div class="contact-card">
            <div class="cc-icon" aria-hidden="true">⏱</div>
            <div>
              <div class="cc-title">Response time</div>
              <div class="cc-body">I read every message and reply as soon as I can.</div>
            </div>
          </div>
          <div class="contact-card">
            <div class="cc-icon" aria-hidden="true">🤝</div>
            <div>
              <div class="cc-title">Partnerships</div>
              <div class="cc-body">Brand collaborations and recipe development. Include details in your message.</div>
            </div>
          </div>
          <div class="contact-card">
            <div class="cc-icon" aria-hidden="true">🐛</div>
            <div>
              <div class="cc-title">Found an error?</div>
              <div class="cc-body">If something in a recipe is wrong or broken, please tell me. I fix things fast.</div>
            </div>
          </div>
        </div>
      </div>

      <div class="form-wrap">
        <div class="form-header">
          <span class="form-dot red" aria-hidden="true"></span>
          <span class="form-dot yellow" aria-hidden="true"></span>
          <span class="form-dot green" aria-hidden="true"></span>
          <span class="form-title">contact@natalidiet.eu</span>
        </div>
        <form id="contact-form" class="contact-form" novalidate>
          <div class="field-row">
            <div class="field">
              <label for="name" class="field-label">Name <span class="required" aria-label="required">*</span></label>
              <input type="text" id="name" name="name" class="field-input" placeholder="Your name" autocomplete="name" required />
            </div>
            <div class="field">
              <label for="email" class="field-label">Email <span class="required" aria-label="required">*</span></label>
              <input type="email" id="email" name="email" class="field-input" placeholder="you@example.com" autocomplete="email" required />
            </div>
          </div>
          <div class="field">
            <label for="subject" class="field-label">Subject</label>
            <input type="text" id="subject" name="subject" class="field-input" placeholder="Recipe question / Collaboration / Other" />
          </div>
          <div class="field">
            <label for="message" class="field-label">Message <span class="required" aria-label="required">*</span></label>
            <textarea id="message" name="message" class="field-input field-textarea" placeholder="Tell me what's on your mind..." rows="7" required></textarea>
            <div class="char-count"><span id="char-count">0</span> / 3000</div>
          </div>
          <div class="field consent-row">
            <input type="checkbox" id="consent" name="consent" required />
            <label for="consent" class="consent-label">I agree to my data being processed to handle this enquiry. See <a href="/privacy-policy">Privacy Policy</a>.</label>
          </div>
          <div id="form-error" class="form-msg form-error" hidden></div>
          <div id="form-success" class="form-msg form-success" hidden>✓ Message sent — I'll get back to you soon!</div>
          <button type="submit" class="submit-btn" id="submit-btn">
            <span class="btn-text">Send Message →</span>
            <span class="btn-loading" hidden>Sending...</span>
          </button>
        </form>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const form     = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText  = submitBtn.querySelector('.btn-text') as HTMLElement;
  const btnLoad  = submitBtn.querySelector('.btn-loading') as HTMLElement;
  const errBox   = document.getElementById('form-error') as HTMLElement;
  const okBox    = document.getElementById('form-success') as HTMLElement;
  const textarea = document.getElementById('message') as HTMLTextAreaElement;
  const counter  = document.getElementById('char-count') as HTMLElement;

  textarea.addEventListener('input', () => {
    counter.textContent = String(textarea.value.length);
    counter.style.color = textarea.value.length > 2700 ? '#ff6b6b' : '';
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errBox.hidden = true; okBox.hidden = true;
    btnText.hidden = true; btnLoad.hidden = false; submitBtn.disabled = true;
    try {
      // Replace with actual API endpoint
      const data = Object.fromEntries(new FormData(form));
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      if (res.ok) {
        form.reset(); counter.textContent = '0'; okBox.hidden = false;
      } else {
        errBox.textContent = 'Something went wrong. Please email contact@natalidiet.eu directly.';
        errBox.hidden = false;
      }
    } catch {
      errBox.textContent = 'Could not send — please email contact@natalidiet.eu directly.';
      errBox.hidden = false;
    } finally {
      btnText.hidden = false; btnLoad.hidden = true; submitBtn.disabled = false;
    }
  });
</script>

<style>
  .contact-page { max-width: 1200px; margin: 0 auto; padding: 64px 48px 100px; }
  .contact-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 72px; align-items: start; }

  .contact-title { font-family: var(--font-serif); font-size: clamp(32px, 4vw, 52px); font-weight: 900; color: var(--nd-forest); line-height: 1.1; letter-spacing: -0.03em; margin-bottom: 18px; }
  .contact-title em { font-style: italic; color: var(--nd-terra); }
  .contact-lead { font-size: 17px; font-weight: 300; color: var(--nd-muted); line-height: 1.7; margin-bottom: 36px; }
  .contact-cards { display: flex; flex-direction: column; gap: 14px; }
  .contact-card { display: flex; gap: 16px; align-items: flex-start; background: var(--nd-warm-white); border: 1px solid var(--nd-border); border-radius: 16px; padding: 18px 20px; transition: border-color 0.2s; }
  .contact-card:hover { border-color: rgba(196,98,58,0.3); }
  .cc-icon { font-size: 22px; flex-shrink: 0; }
  .cc-title { font-size: 13px; font-weight: 700; color: var(--nd-terra); margin-bottom: 3px; text-transform: uppercase; letter-spacing: 0.06em; }
  .cc-body { font-size: 13px; color: var(--nd-muted); line-height: 1.6; }

  .form-wrap { background: var(--nd-warm-white); border: 1px solid var(--nd-border); border-radius: 24px; overflow: hidden; }
  .form-header { background: var(--nd-cream); border-bottom: 1px solid var(--nd-border); padding: 12px 18px; display: flex; align-items: center; gap: 6px; }
  .form-dot { width: 10px; height: 10px; border-radius: 50%; }
  .form-dot.red { background: #ff5f56; }
  .form-dot.yellow { background: #ffbd2e; }
  .form-dot.green { background: #27c93f; }
  .form-title { font-family: var(--font-sans); font-size: 12px; color: var(--nd-muted); letter-spacing: 0.05em; margin-left: 8px; }

  .contact-form { padding: 28px; display: flex; flex-direction: column; gap: 20px; }
  .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .field { display: flex; flex-direction: column; gap: 6px; }
  .field-label { font-size: 12px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--nd-muted); }
  .required { color: var(--nd-terra); }
  .field-input { background: var(--nd-cream); border: 1px solid var(--nd-border); color: var(--nd-text); font-family: var(--font-sans); font-size: 15px; font-weight: 300; padding: 12px 14px; border-radius: 10px; outline: none; transition: border-color 0.15s; resize: none; }
  .field-input:focus { border-color: var(--nd-terra); }
  .field-input::placeholder { color: rgba(44,44,44,0.3); }
  .field-textarea { min-height: 160px; }
  .char-count { font-size: 12px; color: var(--nd-muted); text-align: right; margin-top: 4px; }
  .consent-row { flex-direction: row; align-items: flex-start; gap: 12px; }
  .consent-label { font-size: 13px; color: var(--nd-muted); line-height: 1.55; }
  .consent-label a { color: var(--nd-terra); }
  .form-msg { padding: 12px 16px; border-radius: 10px; font-size: 14px; }
  .form-error { background: rgba(255,107,107,0.08); border: 1px solid rgba(255,107,107,0.2); color: #e05555; }
  .form-success { background: rgba(78,202,139,0.08); border: 1px solid rgba(78,202,139,0.2); color: #2A7A55; }
  .submit-btn { background: var(--nd-terra); color: #fff; border: none; padding: 14px 28px; border-radius: 100px; font-family: var(--font-sans); font-size: 14px; font-weight: 700; cursor: pointer; transition: background 0.15s; align-self: flex-start; }
  .submit-btn:hover { background: var(--nd-forest); }
  .submit-btn:disabled { opacity: 0.6; cursor: not-allowed; }

  @media (max-width: 820px) {
    .contact-page { padding: 40px 20px 72px; }
    .contact-inner { grid-template-columns: 1fr; gap: 44px; }
    .field-row { grid-template-columns: 1fr; }
  }
</style>
