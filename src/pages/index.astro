---
import BaseLayout from '../layouts/BaseLayout.astro';
import RecipeCard from '../components/RecipeCard.astro';
import { getCollection } from 'astro:content';

const allRecipes = await getCollection('recipes');
const featured = allRecipes.filter(r => r.data.featured).slice(0, 4);
const showcase = featured.length >= 4 ? featured : allRecipes.slice(0, 4);

const pillars = [
  { icon: '🥣', title: 'Healthy Soups',           slug: '/blog?category=healthy-soups',             count: '7 articles', active: true  },
  { icon: '🍳', title: 'Healthy Main Dishes',      slug: '/blog?category=healthy-main-dishes',       count: '7 articles', active: true  },
  { icon: '📅', title: 'Meal Plans & Guides',      slug: '/meal-plans',                              count: '6 articles', active: true  },
  { icon: '🥟', title: 'Traditional Made Healthy', slug: '/blog?category=traditional-foods-healthy', count: '7 articles', active: false },
  { icon: '🌍', title: 'Country Recipe Guides',    slug: '/blog?category=country-recipe-guides',     count: '6 articles', active: false },
];

const heroCards = [
  { emoji: '🥣', name: 'Golden Buckwheat Porridge', kcal: 280, time: '10 min', hue: 'breakfast' },
  { emoji: '🥗', name: 'Light Summer Borscht',       kcal: 210, time: '25 min', hue: 'lunch'     },
  { emoji: '🍗', name: 'Herb Chicken & Roasted Veg', kcal: 380, time: '35 min', hue: 'dinner'    },
];
---

<BaseLayout
  title="Natali Diet — Eat Well. Feel Amazing."
  description="Eastern and Central European recipes adapted for healthy eating and weight loss. Real food, real flavour — no bland diets."
  fullWidth={true}
>

<!-- ═══ HERO ══════════════════════════════════════════════════════ -->
<section class="hero">
  <div class="hero-grain" aria-hidden="true"></div>

  <div class="hero-left">
    <div class="hero-eyebrow reveal-hero">
      <span class="eyebrow-dot" aria-hidden="true"></span>
      Healthy Eastern European Eating
    </div>

    <h1 class="hero-title reveal-hero" style="animation-delay:.1s">
      Eat well.<br>
      <em>Lose weight.</em><br>
      Love every bite.
    </h1>

    <p class="hero-desc reveal-hero" style="animation-delay:.22s">
      Real Eastern&nbsp;European recipes — no sad salads, no strange powders.
      Just nourishing food your body and taste&nbsp;buds will love.
    </p>

    <div class="hero-actions reveal-hero" style="animation-delay:.34s">
      <a href="/book" class="hero-btn-primary">Get the Recipe Book →</a>
      <a href="/recipes" class="hero-btn-ghost">Browse free recipes</a>
    </div>

    <div class="hero-stats reveal-hero" style="animation-delay:.46s">
      <div class="hero-stat">
        <div class="stat-n">200+</div>
        <div class="stat-l">Recipes</div>
      </div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div class="hero-stat">
        <div class="stat-n">12k</div>
        <div class="stat-l">Happy readers</div>
      </div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div class="hero-stat">
        <div class="stat-n">4.9★</div>
        <div class="stat-l">Average rating</div>
      </div>
    </div>
  </div>

  <div class="hero-right" aria-hidden="true">
    <div class="hero-cards-wrap">
      {heroCards.map((c, i) => (
        <div class={`hcard hcard-${i+1} hcard-${c.hue}`} style={`animation-delay:${0.5 + i * 0.15}s`}>
          <div class="hcard-emoji">{c.emoji}</div>
          <div class="hcard-info">
            <div class="hcard-name">{c.name}</div>
            <div class="hcard-meta">
              <span class="hcard-kcal">{c.kcal} kcal</span>
              <span class="hcard-sep">·</span>
              <span>{c.time}</span>
            </div>
          </div>
          <div class="hcard-arrow">→</div>
        </div>
      ))}
      <div class="hero-flag-row">
        <span title="Ukrainian">🇺🇦</span>
        <span title="Slovak">🇸🇰</span>
        <span title="Polish">🇵🇱</span>
        <span title="Hungarian">🇭🇺</span>
        <span title="Romanian">🇷🇴</span>
        <span title="English">🇬🇧</span>
      </div>
    </div>
  </div>
</section>

<!-- ═══ TRUST BAR ════════════════════════════════════════════════ -->
<div class="trust-bar" role="list" aria-label="Key facts">
  <div class="trust-track">
    {[
      '🌍 English, Ukrainian & Slovak',
      '📖 200+ recipes',
      '🥗 Nutritionist crafted',
      '✉️ Free weekly recipes',
      '🔥 Every dish calorie-counted',
      '🏆 4.9★ reader rating',
      '🌿 Whole food ingredients only',
    ].map(item => (
      <div class="trust-item" role="listitem">{item}</div>
    ))}
    {/* duplicate for infinite scroll */}
    {[
      '🌍 English, Ukrainian & Slovak',
      '📖 200+ recipes',
      '🥗 Nutritionist crafted',
      '✉️ Free weekly recipes',
      '🔥 Every dish calorie-counted',
      '🏆 4.9★ reader rating',
      '🌿 Whole food ingredients only',
    ].map(item => (
      <div class="trust-item" aria-hidden="true">{item}</div>
    ))}
  </div>
</div>

<!-- ═══ ABOUT ════════════════════════════════════════════════════ -->
<section class="about" id="about">
  <div class="about-visual reveal">
    <div class="about-panel">
      <div class="about-panel-bg" aria-hidden="true"></div>
      <blockquote class="about-blockquote">
        "Eastern European food is
        <em>secretly perfect</em>
        for weight loss."
      </blockquote>
      <div class="about-panel-meta">
        <div class="about-avatar" aria-hidden="true">👩‍🍳</div>
        <div>
          <div class="about-panel-name">Natali</div>
          <div class="about-panel-role">Founder & Certified Nutritionist</div>
        </div>
      </div>
      <div class="about-decorline" aria-hidden="true"></div>
    </div>
  </div>

  <div class="about-content reveal">
    <span class="section-label">About Natali</span>
    <h2 class="section-title">
      Born in Ukraine.<br>
      Cooking for the <em>world.</em>
    </h2>
    <p class="section-body">
      I grew up in a family where food was love — borscht simmering all Sunday,
      fresh bread filling every corner. But I also watched people I love struggle
      with their weight, believing healthy eating meant giving up everything they enjoyed.
    </p>
    <p class="section-body" style="margin-top:14px;">
      It doesn't. I'm a certified nutritionist, and I've spent years proving that
      food which is genuinely <em>delicious</em> and makes you feel incredible
      can be the same plate.
    </p>

    <ul class="highlights" role="list">
      <li class="highlight">
        <div class="highlight-icon" aria-hidden="true">🎓</div>
        <div>
          <strong>Certified Nutritionist</strong>
          <span>Formal training in dietetics & nutritional science</span>
        </div>
      </li>
      <li class="highlight">
        <div class="highlight-icon" aria-hidden="true">🌱</div>
        <div>
          <strong>Whole Food Philosophy</strong>
          <span>No supplements, no weird powders — just real ingredients</span>
        </div>
      </li>
      <li class="highlight">
        <div class="highlight-icon" aria-hidden="true">🌍</div>
        <div>
          <strong>Eastern European Roots</strong>
          <span>Slavic culinary tradition, made lighter & healthier</span>
        </div>
      </li>
    </ul>

    <a href="/about" class="btn-primary about-cta">Read my story →</a>
  </div>
</section>

<!-- ═══ PILLARS ══════════════════════════════════════════════════ -->
<section class="pillars" id="content">
  <div class="pillars-inner">
    <div class="pillars-header reveal">
      <div>
        <span class="section-label" style="color:var(--nd-terra-light);">What you'll find here</span>
        <h2 class="pillars-title">Everything you need to eat <em>beautifully</em><br>and lose weight.</h2>
      </div>
      <a href="/blog" class="pillar-all-link">All articles →</a>
    </div>

    <div class="pillars-grid reveal">
      {pillars.map((p, i) => (
        <a
          href={p.active ? p.slug : '#content'}
          class:list={['pillar-card', { 'pillar-coming': !p.active }]}
          aria-disabled={!p.active ? 'true' : undefined}
        >
          <div class="pillar-num" aria-hidden="true">0{i + 1}</div>
          <div class="pillar-icon" aria-hidden="true">{p.icon}</div>
          <div class="pillar-body">
            <div class="pillar-title">{p.title}</div>
            <div class="pillar-count">{p.count}</div>
          </div>
          {!p.active && <div class="pillar-soon">Soon</div>}
          {p.active && <div class="pillar-arrow" aria-hidden="true">→</div>}
        </a>
      ))}
    </div>
  </div>
</section>

<!-- ═══ RECIPE SHOWCASE ══════════════════════════════════════════ -->
<section class="recipes-section" id="recipes">
  <div class="recipes-inner">
    <div class="recipes-header reveal">
      <div>
        <span class="section-label">Free Recipes</span>
        <h2 class="section-title">A taste of <em>what's waiting.</em></h2>
      </div>
      <a href="/recipes" class="btn-primary">All recipes →</a>
    </div>

    {showcase.length > 0 ? (
      <div class="recipes-grid reveal">
        {showcase.map(r => (
          <RecipeCard
            title={r.data.title}
            slug={r.id}
            description={r.data.description}
            course={r.data.course}
            calories={r.data.calories}
            totalTime={r.data.totalTime}
            tags={r.data.tags}
            image={r.data.image}
          />
        ))}
      </div>
    ) : (
      <div class="placeholder-grid reveal">
        {[
          { img: '/images/buckwheat-porridge.webp', name: 'Golden Buckwheat Porridge with Berries & Honey', course: 'Breakfast', kcal: 280, time: '10 min', hue: 'breakfast' },
          { img: '/images/summer-borscht.webp',     name: 'Light Summer Borscht with Rye Crispbread',        course: 'Lunch',     kcal: 210, time: '25 min', hue: 'lunch'     },
          { img: '/images/chicken-paprikash.webp',  name: 'Kefir Chicken Paprikash with Buckwheat',           course: 'Dinner',    kcal: 380, time: '35 min', hue: 'dinner'    },
          { img: '/images/berry-cottage.webp',      name: 'Berry Cottage Cheese Bowl',                        course: 'Snack',     kcal: 150, time: '5 min',  hue: 'snack'     },
        ].map(r => (
          <a href="/recipes" class={`ph-card ph-${r.hue}`}>
            <div class="ph-visual ph-visual-img">
              <img src={r.img} alt={r.name} loading="lazy" />
            </div>
            <div class="ph-body">
              <div class="ph-course">{r.course}</div>
              <div class="ph-name">{r.name}</div>
              <div class="ph-meta">{r.kcal} kcal · {r.time}</div>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</section>

<!-- ═══ BOOK SECTION ═════════════════════════════════════════════ -->
<section class="book-section" id="book-section">
  <div class="book-inner">
    <div class="book-left reveal">
      <span class="section-label" style="color:var(--nd-terra-light);">The Recipe Book</span>
      <h2 class="book-title">
        Eight days.<br>
        Thirty-two recipes.<br>
        <em>Zero guesswork.</em>
      </h2>
      <p class="book-sub">
        A complete 8-day eating plan with 32 calorie-counted recipes,
        a full shopping list, and prep notes. Everything you need — in one beautiful PDF.
      </p>
      <ul class="book-features" role="list">
        <li><span aria-hidden="true">✓</span> 32 full recipes with nutrition facts</li>
        <li><span aria-hidden="true">✓</span> 8-day meal plan with variety</li>
        <li><span aria-hidden="true">✓</span> Complete shopping list</li>
        <li><span aria-hidden="true">✓</span> Instant PDF download</li>
      </ul>
      <div class="book-price-row">
        <div class="book-price">€24.99</div>
        <a href="/book" class="book-btn">Get the Book →</a>
      </div>
    </div>

    <div class="book-right reveal">
      <div class="book-mockup">
        <div class="book-cover">
          <div class="book-cover-label">Natali Diet</div>
          <div class="book-cover-title">Eastern European<br>Healthy Recipes</div>
          <div class="book-cover-emoji" aria-hidden="true">🌿</div>
        </div>
        <div class="book-shadow" aria-hidden="true"></div>
      </div>
    </div>
  </div>
</section>

<!-- ═══ TESTIMONIALS ════════════════════════════════════════════ -->
<section class="testimonials" id="testimonials">
  <div class="testi-inner">
    <div class="testi-header reveal">
      <span class="section-label">Reader Stories</span>
      <h2 class="section-title">Real people. <em>Real results.</em></h2>
    </div>
    <div class="testi-grid">
      {[
        {
          text: "I\u2019ve tried every diet imaginable. This is the first time eating \u201chealthy\u201d didn\u2019t feel like punishment. I lost 12kg in 4 months and genuinely love cooking now.",
          name: 'Olena M.', origin: 'Kyiv, Ukraine', result: 'Lost 12kg', flag: '🇺🇦',
        },
        {
          text: "As a busy mum of two, I needed recipes that are fast, kid-friendly, and nutritious. Natali\u2019s book is the only cookbook I\u2019ve used more than twice.",
          name: 'Monika K.', origin: 'Bratislava, Slovakia', result: 'Family favourite', flag: '🇸🇰',
        },
        {
          text: "The buckwheat and kefir recipes introduced me to ingredients I'd never used. Genuinely eye-opening. My gut health has improved dramatically.",
          name: 'James T.', origin: 'London, UK', result: 'Down 2 dress sizes', flag: '🇬🇧',
        },
      ].map((t, i) => (
        <article class="testi-card reveal" style={`animation-delay:${i * 0.12}s`}>
          <div class="testi-stars" aria-label="5 out of 5">★★★★★</div>
          <p class="testi-text">{t.text}</p>
          <footer class="testi-footer">
            <div class="testi-avatar" aria-hidden="true">{t.flag}</div>
            <div>
              <div class="testi-name">{t.name}</div>
              <div class="testi-meta">{t.origin} · <strong>{t.result}</strong></div>
            </div>
          </footer>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- ═══ BOOK CTA ══════════════════════════════════════════════════ -->
<section class="cta-band">
  <div class="cta-band-inner reveal">
    <div class="cta-band-text">
      <h2 class="cta-band-title">Everything in <em>one beautiful book.</em></h2>
      <p class="cta-band-sub">Join 12,000+ readers who've changed their relationship with food — without giving up taste, joy, or their culture.</p>
    </div>
    <div class="cta-band-actions">
      <a href="/book" class="cta-band-btn">Get the Recipe Book — €24.99</a>
      <a href="/#newsletter" class="cta-band-ghost">Free recipes first →</a>
    </div>
  </div>
</section>

<!-- ═══ NEWSLETTER ════════════════════════════════════════════════ -->
<section class="newsletter" id="newsletter">
  <div class="nl-inner">
    <div class="reveal">
      <span class="section-label" style="color:var(--nd-terra-light);">Free weekly recipes</span>
      <h2 class="nl-title">Get recipes before<br><em>everyone else does.</em></h2>
      <p class="nl-desc">Every week, one new Eastern European recipe — calorie-counted, step-by-step. Free, forever.</p>
    </div>
    <form class="nl-form reveal" id="nl-form" novalidate>
      <label for="nl-email" class="sr-only">Your email address</label>
      <div class="nl-row">
        <input
          type="email" id="nl-email" name="email"
          class="nl-input" placeholder="your@email.com"
          autocomplete="email" required
        />
        <button type="submit" class="nl-submit">Subscribe →</button>
      </div>
      <p class="nl-note">No spam. Unsubscribe anytime.</p>
      <div id="nl-success" class="nl-success" hidden>✓ Check your inbox for a confirmation email!</div>
    </form>
  </div>
</section>

</BaseLayout>

<style>
/* ── Hero ─────────────────────────────────────────────────────── */
.hero {
  min-height: 100vh;
  background: #0e1a12;
  display: grid;
  grid-template-columns: 55% 45%;
  padding-top: var(--nav-height);
  position: relative;
  overflow: hidden;
}
.hero-grain {
  position: absolute; inset: 0; z-index: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.035'/%3E%3C/svg%3E");
  background-repeat: repeat;
  pointer-events: none;
  opacity: 0.6;
}

.hero-left {
  display: flex; flex-direction: column; justify-content: center;
  padding: 80px 56px 80px 80px;
  position: relative; z-index: 1;
}
.hero-eyebrow {
  display: inline-flex; align-items: center; gap: 10px;
  color: rgba(255,255,255,0.5);
  font-size: 11px; font-weight: 600;
  letter-spacing: 0.18em; text-transform: uppercase;
  margin-bottom: 36px;
}
.eyebrow-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--nd-terra); flex-shrink: 0;
  box-shadow: 0 0 8px var(--nd-terra);
}

.hero-title {
  font-family: var(--font-serif);
  font-size: clamp(48px, 5.5vw, 80px);
  font-weight: 900;
  line-height: 1.04;
  letter-spacing: -0.03em;
  color: #fff;
  margin-bottom: 28px;
}
.hero-title em {
  font-style: italic;
  color: var(--nd-terra);
  background: linear-gradient(135deg, var(--nd-terra) 0%, #e8856a 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.hero-desc {
  font-size: 17px; line-height: 1.75;
  color: rgba(255,255,255,0.55);
  max-width: 420px; margin-bottom: 44px;
  font-weight: 300;
}

.hero-actions { display: flex; align-items: center; gap: 20px; flex-wrap: wrap; }
.hero-btn-primary {
  display: inline-flex; align-items: center;
  background: var(--nd-terra);
  color: #fff; text-decoration: none;
  padding: 15px 32px; border-radius: 100px;
  font-size: 15px; font-weight: 600;
  box-shadow: 0 4px 24px rgba(196,98,58,0.35);
  transition: background 0.25s, transform 0.2s, box-shadow 0.25s;
  white-space: nowrap;
}
.hero-btn-primary:hover {
  background: #d96f45; transform: translateY(-2px);
  box-shadow: 0 8px 32px rgba(196,98,58,0.45);
}
.hero-btn-ghost {
  color: rgba(255,255,255,0.6); text-decoration: none;
  font-size: 14px; font-weight: 500;
  transition: color 0.2s;
}
.hero-btn-ghost:hover { color: #fff; }

.hero-stats {
  display: flex; align-items: center; gap: 28px;
  margin-top: 52px; padding-top: 36px;
  border-top: 1px solid rgba(255,255,255,0.1);
}
.stat-divider { width: 1px; height: 32px; background: rgba(255,255,255,0.12); flex-shrink: 0; }
.stat-n {
  font-family: var(--font-serif);
  font-size: 28px; font-weight: 900; color: #fff;
  letter-spacing: -0.03em; line-height: 1;
}
.stat-l { font-size: 11px; font-weight: 500; color: rgba(255,255,255,0.4); letter-spacing: 0.06em; margin-top: 4px; text-transform: uppercase; }

/* Hero right - recipe cards */
.hero-right {
  display: flex; align-items: center; justify-content: center;
  padding: 60px 48px 60px 0;
  position: relative; z-index: 1;
}
.hero-right::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  background: radial-gradient(ellipse at 60% 50%, rgba(196,98,58,0.12) 0%, transparent 65%);
  pointer-events: none;
}
.hero-cards-wrap { width: 100%; max-width: 360px; display: flex; flex-direction: column; gap: 14px; }

.hcard {
  display: flex; align-items: center; gap: 16px;
  border-radius: 18px; padding: 18px 20px;
  border: 1px solid rgba(255,255,255,0.08);
  cursor: default;
  animation: slideInRight 0.7s ease both;
  transition: transform 0.25s, border-color 0.25s;
}
.hcard:hover { transform: translateX(-4px); border-color: rgba(196,98,58,0.3); }
.hcard-breakfast { background: rgba(232,133,106,0.12); }
.hcard-lunch     { background: rgba(45,74,62,0.5); border-color: rgba(61,99,87,0.5); }
.hcard-dinner    { background: rgba(201,168,76,0.1); }

.hcard-emoji { font-size: 36px; flex-shrink: 0; }
.hcard-info { flex: 1; min-width: 0; }
.hcard-name { font-size: 14px; font-weight: 600; color: #fff; line-height: 1.3; margin-bottom: 5px; }
.hcard-meta { font-size: 12px; color: rgba(255,255,255,0.45); }
.hcard-kcal { color: var(--nd-terra-light); font-weight: 600; }
.hcard-sep { margin: 0 5px; opacity: 0.3; }
.hcard-arrow { color: rgba(255,255,255,0.25); font-size: 16px; flex-shrink: 0; }

.hero-flag-row {
  display: flex; gap: 10px; padding: 16px 20px;
  background: rgba(255,255,255,0.04); border-radius: 14px;
  border: 1px solid rgba(255,255,255,0.07);
  font-size: 22px;
  animation: slideInRight 0.7s ease 0.85s both;
}

/* Reveal hero (no-JS fallback: visible by default, JS adds animation) */
.reveal-hero { animation: fadeUpHero 0.8s ease both; }

@keyframes fadeUpHero {
  from { opacity: 0; transform: translateY(24px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes slideInRight {
  from { opacity: 0; transform: translateX(24px); }
  to   { opacity: 1; transform: translateX(0); }
}

/* ── Trust Bar ────────────────────────────────────────────────── */
.trust-bar {
  background: var(--nd-forest);
  overflow: hidden;
  padding: 0;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}
.trust-track {
  display: flex;
  animation: ticker 40s linear infinite;
  width: max-content;
}
.trust-track:hover { animation-play-state: paused; }
.trust-item {
  padding: 16px 40px;
  font-size: 12px; font-weight: 500;
  color: rgba(255,255,255,0.65);
  letter-spacing: 0.05em;
  white-space: nowrap;
  border-right: 1px solid rgba(255,255,255,0.08);
}
@keyframes ticker {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}

/* ── About ────────────────────────────────────────────────────── */
.about {
  max-width: var(--max-w);
  margin: 0 auto;
  padding: 120px 48px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
}

