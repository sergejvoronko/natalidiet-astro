---
import BaseLayout from '../layouts/BaseLayout.astro';
import RecipeCard from '../components/RecipeCard.astro';
import { getCollection } from 'astro:content';

const allRecipes = await getCollection('recipes');
const featured = allRecipes.filter(r => r.data.featured).slice(0, 4);
const showcase = featured.length >= 4 ? featured : allRecipes.slice(0, 4);

const pillars = [
  { icon: '🥣', title: 'Healthy Soups',             slug: '/blog?category=healthy-soups',             count: '7 articles', active: true  },
  { icon: '🍳', title: 'Healthy Main Dishes',        slug: '/blog?category=healthy-main-dishes',       count: '7 articles', active: true  },
  { icon: '📅', title: 'Meal Plans & Guides',        slug: '/meal-plans',                              count: '6 articles', active: true  },
  { icon: '🥟', title: 'Traditional Made Healthy',   slug: '/blog?category=traditional-foods-healthy', count: '7 articles', active: false },
  { icon: '🌍', title: 'Country Recipe Guides',      slug: '/blog?category=country-recipe-guides',     count: '6 articles', active: false },
];
---

<BaseLayout
  title="Natali Diet — Eat Well. Feel Amazing."
  description="Eastern and Central European recipes adapted for healthy eating and weight loss. Real food, real flavour — no bland diets."
  fullWidth={true}
>
  <!-- HERO -->
  <section class="hero">
    <div class="hero-left">
      <div class="hero-tag">
        <span class="hero-tag-dot" aria-hidden="true"></span>
        Healthy Eating · Established 2025
      </div>
      <h1 class="hero-title">
        Eat food<br>you <em>love.</em><br>Lose weight<br>for real.
      </h1>
      <p class="hero-desc">
        Real Eastern European recipes. No sad salads — just delicious, nourishing food that makes your body thrive.
      </p>
      <div class="hero-actions">
        <a href="/book" class="btn-primary">Get the Recipe Book →</a>
        <a href="/recipes" class="btn-secondary">See free recipes</a>
      </div>
      <div class="hero-stats">
        <div class="stat">
          <div class="stat-num">200+</div>
          <div class="stat-label">Recipes</div>
        </div>
        <div class="stat">
          <div class="stat-num">12k</div>
          <div class="stat-label">Happy readers</div>
        </div>
        <div class="stat">
          <div class="stat-num">4.9★</div>
          <div class="stat-label">Average rating</div>
        </div>
      </div>
    </div>
    <div class="hero-right" aria-hidden="true">
      <div class="hero-visual">
        <div class="hero-bowl">🥗</div>
      </div>
      <div class="floating-tag ftag-1"><span>🥑</span> 320 kcal</div>
      <div class="floating-tag ftag-2"><span>⏱️</span> 20 min</div>
      <div class="floating-tag ftag-3"><span>🌿</span> Whole food</div>
      <div class="floating-tag ftag-4"><span>💚</span> Nutritionist crafted</div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <div class="trust-bar" aria-label="Key facts">
    <div class="trust-item"><span aria-hidden="true">🌍</span> English, Ukrainian &amp; Slovak</div>
    <div class="trust-item"><span aria-hidden="true">📖</span> 200+ recipes</div>
    <div class="trust-item"><span aria-hidden="true">🥗</span> Nutritionist crafted</div>
    <div class="trust-item"><span aria-hidden="true">✉️</span> Free weekly recipes</div>
    <div class="trust-item"><span aria-hidden="true">🔥</span> Calorie-counted</div>
  </div>

  <!-- ABOUT -->
  <section class="about" id="about">
    <div class="about-visual reveal">
      <div class="about-card">
        <div class="about-emoji" aria-hidden="true">👩‍🍳</div>
        <blockquote class="about-quote">
          "I lost 18kg eating food I actually looked forward to every day."
        </blockquote>
        <p class="about-author">— Natali, founder &amp; nutritionist</p>
      </div>
    </div>
    <div class="about-content reveal">
      <span class="section-label">About Natali</span>
      <h2 class="section-title">Born in Ukraine.<br>Cooking for the <em>world.</em></h2>
      <p class="section-body">
        I grew up in a family where food was love — borscht simmering all Sunday, fresh bread filling the whole apartment. But I also watched people I love struggle with their weight, thinking healthy eating meant giving up everything they enjoyed.
      </p>
      <p class="section-body about-body-2">
        It doesn't. I'm a certified nutritionist, and after years of research I've cracked the formula for food that is genuinely delicious <em>and</em> makes you feel incredible.
      </p>
      <div class="highlights">
        <div class="highlight">
          <div class="highlight-icon" aria-hidden="true">🎓</div>
          <div>
            <strong>Certified Nutritionist</strong>
            <span>Formal training in dietetics &amp; nutritional science</span>
          </div>
        </div>
        <div class="highlight">
          <div class="highlight-icon" aria-hidden="true">🌱</div>
          <div>
            <strong>Whole Food Philosophy</strong>
            <span>No supplements, no weird powders — just real food</span>
          </div>
        </div>
        <div class="highlight">
          <div class="highlight-icon" aria-hidden="true">🌍</div>
          <div>
            <strong>Eastern European Roots</strong>
            <span>Slavic culinary tradition, made lighter</span>
          </div>
        </div>
      </div>
      <a href="/about" class="btn-primary about-cta">Read my story →</a>
    </div>
  </section>

  <!-- CONTENT PILLARS -->
  <section class="pillars" id="content">
    <div class="pillars-inner">
      <div class="pillars-header reveal">
        <span class="section-label" style="color: var(--nd-gold);">What you'll find here</span>
        <h2 class="section-title" style="color: #fff;">Five pillars of<br>healthy <em>Eastern European</em> eating</h2>
      </div>
      <div class="pillars-grid reveal">
        {pillars.map(p => (
          <a
            href={p.active ? p.slug : '#content'}
            class:list={['pillar-card', { coming: !p.active }]}
            aria-disabled={!p.active ? 'true' : undefined}
          >
            <span class="pillar-icon" aria-hidden="true">{p.icon}</span>
            <div class="pillar-title">{p.title}</div>
            <div class="pillar-count">{p.count}</div>
            {!p.active && <div class="pillar-soon">Coming soon</div>}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- RECIPE SHOWCASE -->
  <section class="recipes-section" id="recipes">
    <div class="recipes-inner">
      <div class="recipes-header reveal">
        <div>
          <span class="section-label">Free Recipes</span>
          <h2 class="section-title">A taste of<br>what's inside</h2>
        </div>
        <a href="/recipes" class="btn-primary">See all recipes →</a>
      </div>

      {showcase.length > 0 ? (
        <div class="recipes-grid reveal">
          {showcase.map(r => (
            <RecipeCard
              title={r.data.title}
              slug={r.id}
              description={r.data.description}
              course={r.data.course}
              calories={r.data.calories}
              totalTime={r.data.totalTime}
              tags={r.data.tags}
              image={r.data.image}
            />
          ))}
        </div>
      ) : (
        <div class="reveal">
          <div class="placeholder-grid">
            {[
              { emoji: '🥣', name: 'Golden Buckwheat Porridge with Berries', course: 'Breakfast', kcal: 280, time: '10 min' },
              { emoji: '🥗', name: 'Light Summer Borscht with Rye Crispbread', course: 'Lunch', kcal: 210, time: '25 min' },
              { emoji: '🍲', name: 'Herb Chicken & Roasted Vegetables', course: 'Dinner', kcal: 380, time: '35 min' },
              { emoji: '🍓', name: 'Berry Cottage Cheese Bowl', course: 'Snack', kcal: 150, time: '5 min' },
            ].map(r => (
              <a href="/recipes" class="recipe-placeholder card">
                <div class={`placeholder-visual placeholder-${r.course.toLowerCase()}`}>{r.emoji}</div>
                <div class="placeholder-info">
                  <div class="placeholder-course">{r.course}</div>
                  <div class="placeholder-name">{r.name}</div>
                  <div class="placeholder-meta">{r.kcal} kcal · {r.time}</div>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="testimonials" id="testimonials">
    <div class="testi-inner">
      <div class="testi-header reveal">
        <span class="section-label">Reader Stories</span>
        <h2 class="section-title">Real people. <em>Real results.</em></h2>
      </div>
      <div class="testi-grid reveal">
        <article class="testi-card">
          <div class="stars" aria-label="5 out of 5 stars">★★★★★</div>
          <div class="testi-quote" aria-hidden="true">"</div>
          <p class="testi-text">I've tried every diet imaginable. This is the first time eating "healthy" didn't feel like punishment. I lost 12kg in 4 months and genuinely love cooking now.</p>
          <footer class="testi-author">
            <div class="testi-avatar" aria-hidden="true">🇺🇦</div>
            <div>
              <div class="testi-name">Olena M.</div>
              <div class="testi-origin">Kyiv, Ukraine · Lost 12kg</div>
            </div>
          </footer>
        </article>
        <article class="testi-card">
          <div class="stars" aria-label="5 out of 5 stars">★★★★★</div>
          <div class="testi-quote" aria-hidden="true">"</div>
          <p class="testi-text">As a busy mum of two, I needed recipes that are fast, kid-friendly, and nutritious. Natali's book is the only cookbook I've used more than twice.</p>
          <footer class="testi-author">
            <div class="testi-avatar" aria-hidden="true">🇸🇰</div>
            <div>
              <div class="testi-name">Monika K.</div>
              <div class="testi-origin">Bratislava, Slovakia</div>
            </div>
          </footer>
        </article>
        <article class="testi-card">
          <div class="stars" aria-label="5 out of 5 stars">★★★★★</div>
          <div class="testi-quote" aria-hidden="true">"</div>
          <p class="testi-text">The buckwheat and kefir recipes introduced me to ingredients I'd never used. Genuinely eye-opening. My gut health has improved dramatically.</p>
          <footer class="testi-author">
            <div class="testi-avatar" aria-hidden="true">🇬🇧</div>
            <div>
              <div class="testi-name">James T.</div>
              <div class="testi-origin">London, UK · Down 2 dress sizes</div>
            </div>
          </footer>
        </article>
      </div>
    </div>
  </section>

  <!-- BOOK CTA -->
  <section class="book-cta" id="book">
    <div class="book-cta-inner reveal">
      <span class="cta-emoji" aria-hidden="true">🌿</span>
      <h2 class="cta-title">Start eating food<br>you're <em>proud of.</em></h2>
      <p class="cta-sub">Join 12,000+ readers who've changed their relationship with food — without giving up taste, joy, or their culture.</p>
      <div class="cta-actions">
        <a href="/book" class="btn-primary btn-large">Get the Recipe Book — €24.99</a>
        <a href="/#newsletter" class="btn-secondary">Get free weekly recipes first</a>
      </div>
    </div>
  </section>

  <!-- NEWSLETTER -->
  <section class="newsletter-section" id="newsletter">
    <div class="newsletter-inner">
      <div class="reveal">
        <span class="section-label" style="color: var(--nd-gold);">Free weekly recipes</span>
        <h2 class="section-title" style="color: #fff; margin-bottom: 16px;">Get recipes before<br>everyone <em style="color: var(--nd-terra-light)">else does.</em></h2>
        <p style="font-size: 16px; color: rgba(255,255,255,0.55); font-weight: 300; line-height: 1.7; max-width: 400px;">
          Every week, one new Eastern European recipe — calorie-counted, step-by-step. Free, forever.
        </p>
      </div>
      <form class="nl-form reveal" id="nl-form" novalidate>
        <label for="nl-email" class="sr-only">Your email address</label>
        <div class="nl-row">
          <input
            type="email" id="nl-email" name="email"
            class="nl-input" placeholder="your@email.com"
            autocomplete="email" required
          />
          <button type="submit" class="nl-btn">Subscribe →</button>
        </div>
        <p class="nl-note">No spam. Unsubscribe anytime.</p>
        <div id="nl-success" class="nl-success" hidden>
          ✓ Check your inbox for a confirmation email!
        </div>
      </form>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ──────────────────────────────────────────────────── */
  .hero {
    min-height: 100vh;
    display: grid; grid-template-columns: 1fr 1fr;
    padding-top: var(--nav-height);
    position: relative; overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute; top: -200px; right: -200px;
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(196,98,58,0.08) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-left {
    display: flex; flex-direction: column; justify-content: center;
    padding: 80px 60px 80px 80px;
    animation: fadeUp 0.9s ease 0.2s both;
  }
  .hero-tag {
    display: inline-flex; align-items: center; gap: 10px;
    background: rgba(196,98,58,0.1); color: var(--nd-terra);
    font-size: 12px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase;
    padding: 7px 16px; border-radius: 100px;
    margin-bottom: 32px; width: fit-content;
  }
  .hero-tag-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--nd-terra); }
  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(42px, 5vw, 68px); font-weight: 900;
    line-height: 1.08; color: var(--nd-forest);
    letter-spacing: -0.025em; margin-bottom: 28px;
  }
  .hero-title em { font-style: italic; color: var(--nd-terra); }
  .hero-desc {
    font-size: 17px; line-height: 1.75;
    color: var(--nd-muted); max-width: 420px; margin-bottom: 44px; font-weight: 300;
  }
  .hero-actions { display: flex; align-items: center; gap: 20px; flex-wrap: wrap; }
  .hero-stats {
    display: flex; gap: 36px; margin-top: 56px;
    padding-top: 36px; border-top: 1px solid rgba(45,74,62,0.12);
  }
  .stat-num {
    font-family: var(--font-serif); font-size: 30px; font-weight: 900;
    color: var(--nd-forest); letter-spacing: -0.03em;
  }
  .stat-label {
    font-size: 12px; font-weight: 500; color: var(--nd-muted);
    text-transform: uppercase; letter-spacing: 0.08em; margin-top: 2px;
  }
  .hero-right {
    position: relative;
    display: flex; align-items: center; justify-content: center;
    background: var(--nd-forest); overflow: hidden;
    animation: fadeUp 0.9s ease 0.45s both;
  }
  .hero-right::before {
    content: '';
    position: absolute; inset: 0;
    background:
      radial-gradient(circle at 30% 70%, rgba(196,98,58,0.25) 0%, transparent 50%),
      radial-gradient(circle at 70% 20%, rgba(201,168,76,0.15) 0%, transparent 40%);
  }
  .hero-visual { position: relative; z-index: 1; }
  .hero-bowl { font-size: 160px; filter: drop-shadow(0 20px 40px rgba(0,0,0,0.3)); animation: float 6s ease-in-out infinite; }
  .floating-tag {
    position: absolute; z-index: 2;
    background: #fff; border-radius: 14px;
    padding: 10px 16px; font-size: 13px; font-weight: 600;
    color: var(--nd-text); box-shadow: 0 8px 24px rgba(0,0,0,0.15); white-space: nowrap;
  }
  .ftag-1 { top: 20%; left: 5%; animation: float 5s ease-in-out 0.5s infinite; }
  .ftag-2 { top: 30%; right: 5%; animation: float 5s ease-in-out 1s infinite; }
  .ftag-3 { bottom: 28%; left: 8%; animation: float 5s ease-in-out 1.5s infinite; }
  .ftag-4 { bottom: 22%; right: 5%; animation: float 5s ease-in-out 2s infinite; }
  .floating-tag span { margin-right: 6px; }

  /* ── Trust Bar ─────────────────────────────────────────────── */
  .trust-bar {
    background: var(--nd-forest);
    padding: 20px 48px;
    display: flex; align-items: center; justify-content: center; gap: 48px; flex-wrap: wrap;
  }
  .trust-item { display: flex; align-items: center; gap: 10px; color: rgba(255,255,255,0.7); font-size: 13px; font-weight: 500; }
  .trust-item span { font-size: 17px; }

  /* ── About ──────────────────────────────────────────────────── */
  .about {
    max-width: var(--max-w); margin: 0 auto;
    padding: 120px 48px;
    display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center;
  }
  .about-card {
    background: var(--nd-forest); border-radius: 32px;
    padding: 60px 48px; position: relative; overflow: hidden;
    aspect-ratio: 4/5;
    display: flex; flex-direction: column; justify-content: flex-end;
  }
  .about-card::before {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(circle at 60% 30%, rgba(196,98,58,0.3) 0%, transparent 60%);
  }
  .about-emoji { font-size: 110px; position: absolute; top: 40px; right: 24px; animation: float 7s ease-in-out infinite; }
  .about-quote {
    position: relative; z-index: 1;
    font-family: var(--font-serif); font-size: 24px; font-style: italic;
    color: #fff; line-height: 1.45; margin-bottom: 16px; font-weight: 400;
  }
  .about-author { position: relative; z-index: 1; font-size: 12px; color: rgba(255,255,255,0.55); font-weight: 500; text-transform: uppercase; letter-spacing: 0.1em; }
  .about-body-2 { margin-top: 14px; }
  .highlights { display: flex; flex-direction: column; gap: 18px; margin-top: 36px; }
  .highlight { display: flex; align-items: flex-start; gap: 16px; }
  .highlight-icon { width: 44px; height: 44px; background: rgba(196,98,58,0.1); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0; }
  .highlight strong { display: block; font-size: 14px; font-weight: 600; color: var(--nd-forest); margin-bottom: 2px; }
  .highlight span { font-size: 13px; color: var(--nd-muted); }
  .about-cta { margin-top: 32px; }

  /* ── Pillars ────────────────────────────────────────────────── */
  .pillars { background: var(--nd-forest); padding: 100px 0; }
  .pillars-inner { max-width: var(--max-w); margin: 0 auto; padding: 0 48px; }
  .pillars-header { text-align: center; margin-bottom: 60px; }
  .pillars-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 16px; }
  .pillar-card {
    background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
    border-radius: 20px; padding: 36px 20px; text-align: center; text-decoration: none;
    transition: transform 0.25s, border-color 0.25s, background 0.25s;
  }
  .pillar-card:not(.coming):hover { transform: translateY(-4px); border-color: rgba(196,98,58,0.5); background: rgba(196,98,58,0.1); }
  .pillar-card.coming { opacity: 0.5; cursor: default; }
  .pillar-icon { font-size: 40px; display: block; margin-bottom: 16px; }
  .pillar-title { font-family: var(--font-serif); font-size: 15px; font-weight: 700; color: #fff; margin-bottom: 8px; line-height: 1.3; }
  .pillar-count { font-size: 12px; color: rgba(255,255,255,0.4); }
  .pillar-soon { display: inline-block; margin-top: 12px; background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.45); font-size: 10px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; padding: 4px 10px; border-radius: 100px; }

  /* ── Recipes ────────────────────────────────────────────────── */
  .recipes-section { padding: 100px 0; }
  .recipes-inner { max-width: var(--max-w); margin: 0 auto; padding: 0 48px; }
  .recipes-header { display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 52px; }
  .recipes-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
  .placeholder-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
  .recipe-placeholder { text-decoration: none; }
  .placeholder-visual { height: 180px; border-radius: 20px 20px 0 0; display: flex; align-items: center; justify-content: center; font-size: 64px; }
  .placeholder-breakfast { background: linear-gradient(135deg, #FFF0EB, #FFD9CC); }
  .placeholder-lunch     { background: linear-gradient(135deg, #EBF2EF, #C8DDD5); }
  .placeholder-dinner    { background: linear-gradient(135deg, #EEE9F8, #D5C9EF); }
  .placeholder-snack     { background: linear-gradient(135deg, #FFFBEB, #FAEBC6); }
  .placeholder-info { padding: 20px; background: var(--nd-warm-white); border-radius: 0 0 20px 20px; }
  .placeholder-course { font-size: 11px; font-weight: 600; color: var(--nd-terra); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 6px; }
  .placeholder-name { font-family: var(--font-serif); font-size: 17px; font-weight: 700; color: var(--nd-forest); margin-bottom: 8px; line-height: 1.3; }
  .placeholder-meta { font-size: 13px; color: var(--nd-muted); }

  /* ── Testimonials ───────────────────────────────────────────── */
  .testimonials { background: #F2ECE3; padding: 100px 0; }
  .testi-inner { max-width: var(--max-w); margin: 0 auto; padding: 0 48px; }
  .testi-header { text-align: center; margin-bottom: 60px; }
  .testi-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .testi-card { background: #fff; border-radius: 24px; padding: 36px; box-shadow: var(--shadow-card); }
  .stars { color: var(--nd-gold); font-size: 14px; margin-bottom: 12px; }
  .testi-quote { font-size: 48px; font-family: var(--font-serif); color: var(--nd-terra); line-height: 1; margin-bottom: 12px; }
  .testi-text { font-size: 15px; line-height: 1.7; color: var(--nd-text); margin-bottom: 24px; font-style: italic; font-weight: 300; }
  .testi-author { display: flex; align-items: center; gap: 12px; }
  .testi-avatar { width: 44px; height: 44px; border-radius: 50%; background: var(--nd-forest); display: flex; align-items: center; justify-content: center; font-size: 22px; flex-shrink: 0; }
  .testi-name { font-size: 14px; font-weight: 600; color: var(--nd-forest); }
  .testi-origin { font-size: 12px; color: var(--nd-muted); margin-top: 2px; }

  /* ── Book CTA ───────────────────────────────────────────────── */
  .book-cta { padding: 120px 48px; text-align: center; position: relative; overflow: hidden; }
  .book-cta::before {
    content: '';
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(196,98,58,0.07) 0%, transparent 70%);
    pointer-events: none;
  }
  .book-cta-inner { position: relative; z-index: 1; max-width: 680px; margin: 0 auto; }
  .cta-emoji { font-size: 72px; display: block; margin-bottom: 28px; }
  .cta-title { font-family: var(--font-serif); font-size: clamp(36px, 5vw, 60px); font-weight: 900; color: var(--nd-forest); line-height: 1.1; letter-spacing: -0.03em; margin-bottom: 20px; }
  .cta-title em { font-style: italic; color: var(--nd-terra); }
