---
interface Props {
  title: string;
  slug: string;
  description: string;
  course: string;
  calories: number;
  totalTime: number;
  tags?: string[];
  image?: string;
  featured?: boolean;
}

const { title, slug, description, course, calories, totalTime, tags = [], image, featured = false } = Astro.props;

const courseColors: Record<string, string> = {
  breakfast: 'linear-gradient(150deg, #FFF0EB 0%, #FFDDD1 100%)',
  lunch:     'linear-gradient(150deg, #EBF2EF 0%, #C8DDD5 100%)',
  dinner:    'linear-gradient(150deg, #EEE9F8 0%, #D5C9EF 100%)',
  snack:     'linear-gradient(150deg, #FFFBEB 0%, #FAEBC6 100%)',
};

const courseEmojis: Record<string, string> = {
  breakfast: '🥣', lunch: '🥗', dinner: '🍲', snack: '🍎',
};

const bg = courseColors[course] ?? courseColors.lunch;
const emoji = courseEmojis[course] ?? '🍽️';
---

<a href={`/recipes/${slug}`} class:list={['recipe-card', 'card', { featured }]} aria-label={title}>
  <div class="recipe-visual" style={`background: ${bg}`}>
    {image
      ? <img src={image} alt={title} width="400" height="280" loading="lazy" class="recipe-img" />
      : <span class="recipe-emoji" aria-hidden="true">{emoji}</span>
    }
    <span class={`badge badge-${course} recipe-badge`}>
      <span class="dot"></span>{course}
    </span>
  </div>
  <div class="recipe-info">
    <h3 class="recipe-title">{title}</h3>
    <p class="recipe-desc">{description}</p>
    <div class="recipe-meta">
      <span class="meta-item">⏱ {totalTime} min</span>
      <span class="meta-item">🔥 {calories} kcal</span>
    </div>
    {tags.length > 0 && (
      <div class="recipe-tags">
        {tags.slice(0, 3).map(tag => <span class="pill recipe-tag">{tag}</span>)}
      </div>
    )}
  </div>
</a>

<style>
  .recipe-card {
    text-decoration: none;
    display: flex; flex-direction: column;
    border-radius: 22px;
    overflow: hidden;
    background: var(--nd-warm-white);
    box-shadow: var(--shadow-card);
    transition: transform 0.25s, box-shadow 0.25s;
  }
  .recipe-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-hover);
  }
  .recipe-visual {
    position: relative;
    height: 200px;
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
  }
  .recipe-emoji { font-size: 72px; }
  .recipe-img { width: 100%; height: 100%; object-fit: cover; }
  .recipe-badge {
    position: absolute; top: 14px; left: 14px;
    text-transform: capitalize;
  }
  .recipe-info { padding: 24px 24px 20px; flex: 1; display: flex; flex-direction: column; gap: 10px; }
  .recipe-title {
    font-family: var(--font-serif);
    font-size: 19px; font-weight: 700;
    color: var(--nd-forest);
    line-height: 1.25;
    letter-spacing: -0.02em;
  }
  .recipe-desc {
    font-size: 13px; color: var(--nd-muted);
    line-height: 1.6; font-weight: 300;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .recipe-meta { display: flex; gap: 16px; }
  .meta-item { font-size: 13px; font-weight: 500; color: var(--nd-muted); }
  .recipe-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 4px; }
  .recipe-tag { font-size: 11px; padding: 3px 10px; }
</style>
