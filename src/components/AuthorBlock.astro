---
interface Props {
  compact?: boolean;
}
const { compact = false } = Astro.props;
---

<aside class:list={['author-block', { 'author-block--compact': compact }]}>
  <div class="author-photo">
    <img
      src="/images/natali-profile.webp"
      alt="Natali — certified nutritionist and founder of Natali Diet"
      width="80"
      height="80"
      loading="lazy"
      onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
    />
    <div class="author-avatar-fallback" aria-hidden="true">👩‍🍳</div>
  </div>
  <div class="author-info">
    <div class="author-name">Natali</div>
    <div class="author-role">Certified Nutritionist · Founder of Natali Diet</div>
    {!compact && (
      <p class="author-bio">
        Born in Ukraine, trained in nutritional science. I create Eastern European recipes
        adapted for healthy eating — real food that tastes good and works for your body.
      </p>
    )}
    <a href="/about" class="author-link">About Natali →</a>
  </div>
</aside>

<style>
  .author-block {
    display: flex; gap: 20px; align-items: flex-start;
    background: var(--nd-cream);
    border: 1px solid var(--nd-border);
    border-radius: 20px;
    padding: 28px;
    margin-top: 40px;
  }
  .author-block--compact { padding: 20px; gap: 14px; }

  .author-photo {
    flex-shrink: 0;
    width: 72px; height: 72px;
    border-radius: 50%;
    overflow: hidden;
    background: var(--nd-forest);
    display: flex; align-items: center; justify-content: center;
  }
  .author-block--compact .author-photo { width: 52px; height: 52px; }

  .author-photo img {
    width: 100%; height: 100%; object-fit: cover; display: block;
  }
  .author-avatar-fallback {
    display: none;
    font-size: 32px;
    align-items: center; justify-content: center;
    width: 100%; height: 100%;
  }

  .author-name {
    font-family: var(--font-serif);
    font-size: 18px; font-weight: 700;
    color: var(--nd-forest);
    margin-bottom: 2px;
  }
  .author-block--compact .author-name { font-size: 15px; }

  .author-role {
    font-size: 12px; color: var(--nd-muted);
    font-weight: 500; margin-bottom: 10px;
  }

  .author-bio {
    font-size: 14px; color: var(--nd-text); line-height: 1.7;
    font-weight: 300; margin-bottom: 12px;
  }

  .author-link {
    font-size: 13px; font-weight: 600;
    color: var(--nd-terra); text-decoration: none;
    transition: text-decoration 0.15s;
  }
  .author-link:hover { text-decoration: underline; }
</style>
