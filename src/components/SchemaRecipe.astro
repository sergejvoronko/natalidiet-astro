---
interface Ingredient { amount: string; name: string; }

interface Props {
  title: string;
  description: string;
  image?: string;
  prepTime: number;
  cookTime: number;
  totalTime: number;
  servings: number;
  calories: number;
  protein: number;
  carbs: number;
  fat: number;
  fibre?: number;
  tags?: string[];
  ingredients: Ingredient[];
  steps: string[];
  publishDate: Date;
}

const p = Astro.props;
const siteUrl = 'https://natalidiet.eu';

const dietMap: Record<string, string> = {
  vegetarian: 'https://schema.org/VegetarianDiet',
  vegan: 'https://schema.org/VeganDiet',
  'gluten-free': 'https://schema.org/GlutenFreeDiet',
};
const suitableForDiet = [...new Set((p.tags ?? []).filter(t => t in dietMap).map(t => dietMap[t]))];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Recipe',
  name: p.title,
  description: p.description,
  author: { '@type': 'Person', name: 'Natali', url: siteUrl + '/about' },
  image: p.image ? (p.image.startsWith('http') ? p.image : siteUrl + p.image) : undefined,
  datePublished: p.publishDate.toISOString().split('T')[0],
  prepTime: `PT${p.prepTime}M`,
  cookTime: `PT${p.cookTime}M`,
  totalTime: `PT${p.totalTime}M`,
  recipeYield: `${p.servings} serving${p.servings > 1 ? 's' : ''}`,
  recipeCategory: 'Healthy',
  recipeCuisine: 'Eastern European',
  keywords: (p.tags ?? []).join(', ') || undefined,
  ...(suitableForDiet.length > 0 && { suitableForDiet }),
  nutrition: {
    '@type': 'NutritionInformation',
    calories: `${p.calories} kcal`,
    proteinContent: `${p.protein}g`,
    carbohydrateContent: `${p.carbs}g`,
    fatContent: `${p.fat}g`,
    ...(p.fibre != null && { fiberContent: `${p.fibre}g` }),
    servingSize: '1 serving',
  },
  recipeIngredient: p.ingredients.map(i => `${i.amount} ${i.name}`),
  recipeInstructions: p.steps.map((step, i) => ({
    '@type': 'HowToStep',
    position: i + 1,
    text: step,
  })),
  publisher: {
    '@type': 'Organization',
    name: 'Natali Diet',
    url: siteUrl,
  },
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
